{
  "family": "{{ project }}-{{ env }}-svc-{{ item }}",
  "networkMode": "awsvpc",
  "executionRoleArn": "arn:aws:iam::{{ aws_account.stdout }}:role/{{ project }}-{{ env }}-ecs-execution",
  "taskRoleArn": "arn:aws:iam::{{ aws_account.stdout }}:role/{{ project }}-{{ env }}-ecs-task",
  "cpu": "256",
  "memory": "512",
  "requiresCompatibilities": ["FARGATE"],
  "containerDefinitions": [
    {
      "name": "svc-{{ item }}",
      "image": "{{ ecr_registry }}/{{ project }}-{{ env }}-svc-{{ item }}:{{ image_tag }}",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8080,
          "hostPort": 8080,
          "protocol": "tcp"
        }
      ],
      "environment": [
        { "name": "PORT", "value": "8080" },
        { "name": "NODE_ENV", "value": "{{ env }}" },
        { "name": "DB_HOST", "value": "{{ db_host }}" },
        { "name": "DB_USER", "value": "{{ db_user }}" },
        { "name": "DB_PASS", "value": "{{ db_pass }}" },
        { "name": "DB_NAME", "value": "{{ db_name }}" },
        { "name": "REDIS_HOST", "value": "{{ redis_host }}" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/{{ project }}-{{ env }}/ecs/{{ item }}",
          "awslogs-region": "{{ aws_region }}",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}
