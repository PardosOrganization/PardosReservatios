{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "ProxySecretsAccess",
      "Effect": "Allow",
      "Action": "secretsmanager:GetSecretValue",
      "Resource": "arn:aws:secretsmanager:${region}:${account_id}:secret:${project}/rds-credentials-*"
    },
    {
      "Sid": "ProxyKMSDecrypt",
      "Effect": "Allow",
      "Action": "kms:Decrypt",
      "Resource": "arn:aws:kms:${region}:${account_id}:key/*",
      "Condition": {
        "StringEquals": {
          "kms:ViaService": "secretsmanager.${region}.amazonaws.com"
        }
      }
    }
  ]
}
