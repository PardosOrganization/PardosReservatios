{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "SQSReservas",
      "Effect": "Allow",
      "Action": [
        "sqs:SendMessage",
        "sqs:ReceiveMessage",
        "sqs:DeleteMessage",
        "sqs:GetQueueAttributes"
      ],
      "Resource": "arn:aws:sqs:${region}:${account_id}:${project}-reservas-fifo.fifo"
    },
    {
      "Sid": "SNSNotificaciones",
      "Effect": "Allow",
      "Action": "sns:Publish",
      "Resource": "arn:aws:sns:${region}:${account_id}:${project}-notificaciones"
    },
    {
      "Sid": "XRayTrazas",
      "Effect": "Allow",
      "Action": [
        "xray:PutTraceSegments",
        "xray:PutTelemetryRecords"
      ],
      "Resource": "*"
    }
  ]
}
