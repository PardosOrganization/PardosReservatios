{
  "Version": "2012-10-17",
  "_comment": "Capa de datos. RESTRICCION DE SEGURIDAD: NO incluye rds:DeleteDBCluster ni kms:ScheduleKeyDeletion. Ningun rol ejecutado por la pipeline puede destruir infraestructura de datos.",
  "Statement": [
    {
      "Sid": "AuroraSinBorradoCritico",
      "Effect": "Allow",
      "Action": [
        "rds:CreateDBCluster",
        "rds:ModifyDBCluster",
        "rds:DescribeDBClusters",
        "rds:CreateDBInstance",
        "rds:DeleteDBInstance",
        "rds:ModifyDBInstance",
        "rds:DescribeDBInstances",
        "rds:CreateDBSubnetGroup",
        "rds:DeleteDBSubnetGroup",
        "rds:DescribeDBSubnetGroups",
        "rds:CreateDBClusterParameterGroup",
        "rds:ModifyDBClusterParameterGroup",
        "rds:CreateDBClusterSnapshot",
        "rds:DeleteDBClusterSnapshot",
        "rds:CopyDBClusterSnapshot",
        "rds:AddTagsToResource"
      ],
      "Resource": [
        "arn:aws:rds:${region}:${account_id}:cluster:${project}-aurora-*",
        "arn:aws:rds:${region}:${account_id}:db:${project}-aurora-*",
        "arn:aws:rds:${region}:${account_id}:subgrp:${project}-*",
        "arn:aws:rds:${region}:${account_id}:cluster-pg:${project}-*",
        "arn:aws:rds:${region}:${account_id}:cluster-snapshot:${project}-*"
      ]
    },
    {
      "Sid": "RDSProxy",
      "Effect": "Allow",
      "Action": [
        "rds:CreateDBProxy",
        "rds:DeleteDBProxy",
        "rds:ModifyDBProxy",
        "rds:DescribeDBProxies",
        "rds:RegisterDBProxyTargets",
        "rds:DeregisterDBProxyTargets",
        "rds:DescribeDBProxyTargetGroups",
        "rds:DescribeDBProxyTargets"
      ],
      "Resource": "arn:aws:rds:${region}:${account_id}:db-proxy:${project}-proxy-*"
    },
    {
      "Sid": "PassRoleProxy",
      "Effect": "Allow",
      "Action": "iam:PassRole",
      "Resource": "arn:aws:iam::${account_id}:role/PardosRDSProxyRole"
    },
    {
      "Sid": "SecretsManager",
      "Effect": "Allow",
      "Action": [
        "secretsmanager:CreateSecret",
        "secretsmanager:DeleteSecret",
        "secretsmanager:UpdateSecret",
        "secretsmanager:PutSecretValue",
        "secretsmanager:DescribeSecret",
        "secretsmanager:GetSecretValue",
        "secretsmanager:ListSecrets",
        "secretsmanager:RotateSecret",
        "secretsmanager:TagResource"
      ],
      "Resource": "arn:aws:secretsmanager:${region}:${account_id}:secret:${project}/*"
    },
    {
      "Sid": "KMSSinScheduleDeletion",
      "Effect": "Allow",
      "Action": [
        "kms:CreateKey",
        "kms:DescribeKey",
        "kms:EnableKeyRotation",
        "kms:ListKeys",
        "kms:CreateAlias",
        "kms:DeleteAlias",
        "kms:UpdateAlias",
        "kms:ListAliases",
        "kms:PutKeyPolicy",
        "kms:GetKeyPolicy",
        "kms:TagResource",
        "kms:Encrypt",
        "kms:Decrypt",
        "kms:ReEncrypt*",
        "kms:GenerateDataKey*"
      ],
      "Resource": "*"
    },
    {
      "Sid": "Backup",
      "Effect": "Allow",
      "Action": [
        "backup:CreateBackupPlan",
        "backup:DeleteBackupPlan",
        "backup:UpdateBackupPlan",
        "backup:GetBackupPlan",
        "backup:CreateBackupVault",
        "backup:DeleteBackupVault",
        "backup:DescribeBackupVault",
        "backup:CreateBackupSelection",
        "backup:DeleteBackupSelection",
        "backup:GetBackupSelection",
        "backup:ListBackupPlans",
        "backup:ListBackupVaults",
        "backup:PutBackupVaultAccessPolicy",
        "backup:TagResource"
      ],
      "Resource": [
        "arn:aws:backup:${region}:${account_id}:backup-vault:${project}-vault",
        "arn:aws:backup:${region}:${account_id}:backup-plan:*"
      ]
    }
  ]
}
