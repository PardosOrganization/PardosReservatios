{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "S3FrontendBuckets",
      "Effect": "Allow",
      "Action": [
        "s3:CreateBucket",
        "s3:DeleteBucket",
        "s3:PutBucketPolicy",
        "s3:PutBucketWebsite",
        "s3:PutBucketPublicAccessBlock",
        "s3:PutEncryptionConfiguration",
        "s3:PutBucketVersioning",
        "s3:PutBucketTagging",
        "s3:GetBucketPolicy",
        "s3:GetEncryptionConfiguration"
      ],
      "Resource": [
        "arn:aws:s3:::${project}-frontend-*",
        "arn:aws:s3:::${project}-empleados-*"
      ]
    },
    {
      "Sid": "S3FrontendObjects",
      "Effect": "Allow",
      "Action": [
        "s3:PutObject",
        "s3:GetObject",
        "s3:DeleteObject",
        "s3:ListBucket"
      ],
      "Resource": [
        "arn:aws:s3:::${project}-frontend-*",
        "arn:aws:s3:::${project}-frontend-*/*",
        "arn:aws:s3:::${project}-empleados-*",
        "arn:aws:s3:::${project}-empleados-*/*"
      ]
    }
  ]
}
