  "links": [],
  "liveNow": false,
  "templating": {
    "list": [
      {
        "name": "servicio",
        "label": "Servicio",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "Prometheus" },
        "query": "label_values(http_requests_total, job)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": { "selected": true, "text": ["All"], "value": ["$__all"] },
        "options": [],
        "sort": 1
      }
    ]
  },
  "panels": [
    {
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 0 },
      "id": 1,
      "title": "Tasa de Éxito por Servicio (SLO ≥ 99.5%)",
      "type": "gauge",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 3,
          "min": 0.95,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.99 },
              { "color": "green", "value": 0.995 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "editorMode": "code",
          "expr": "((sum(rate(http_requests_total{job=~\"$servicio\"}[$__range])) by (job) - (sum(rate(http_requests_total{job=~\"$servicio\", status_code=~\"5..\"}[$__range])) by (job) or (sum(rate(http_requests_total{job=~\"$servicio\"}[$__range])) by (job) * 0))) / sum(rate(http_requests_total{job=~\"$servicio\"}[$__range])) by (job))",
          "legendFormat": "{{job}}",
          "range": true,
          "refId": "A"
        }
      ]
    },
    {
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 0 },
      "id": 2,
      "title": "Disponibilidad de Targets (rango) — métrica up",
      "type": "gauge",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 3,
          "min": 0.95,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.99 },
              { "color": "green", "value": 0.995 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "editorMode": "code",
          "expr": "avg_over_time(up{job=~\"svc-.*\", job=~\"$servicio\"}[$__range])",
          "legendFormat": "{{job}}",
          "range": true,
          "refId": "A"
        }
      ]
    },
    {
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 7 },
      "id": 3,
      "title": "Tasa de Éxito en el Tiempo (ventana 5m)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 3,
          "min": 0.95,
          "max": 1,
          "custom": { "thresholdsStyle": { "mode": "line" } },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "transparent", "value": null },
              { "color": "red", "value": 0.995 }
            ]
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "editorMode": "code",
          "expr": "((sum(rate(http_requests_total{job=~\"$servicio\"}[5m])) by (job) - (sum(rate(http_requests_total{job=~\"$servicio\", status_code=~\"5..\"}[5m])) by (job) or (sum(rate(http_requests_total{job=~\"$servicio\"}[5m])) by (job) * 0))) / sum(rate(http_requests_total{job=~\"$servicio\"}[5m])) by (job))",
          "legendFormat": "{{job}}",
          "range": true,
          "refId": "A"
        }
      ]
    },
    {
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 7 },
      "id": 4,
      "title": "Latencia p50 / p95 / p99",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "editorMode": "code",
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket{job=~\"$servicio\"}[5m])) by (le, job))",
          "legendFormat": "{{job}} p50",
          "range": true,
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "editorMode": "code",
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket{job=~\"$servicio\"}[5m])) by (le, job))",
          "legendFormat": "{{job}} p95",
          "range": true,
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "editorMode": "code",
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_seconds_bucket{job=~\"$servicio\"}[5m])) by (le, job))",
          "legendFormat": "{{job}} p99",
          "range": true,
          "refId": "C"
        }
      ]
    },
    {
      "gridPos": { "h": 6, "w": 24, "x": 0, "y": 15 },
      "id": 5,
      "title": "Estado de Targets (1 = arriba, 0 = caído)",
      "type": "state-timeline",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 0, "fillOpacity": 70 },
          "mappings": [
            { "type": "value", "options": { "1": { "text": "UP", "color": "green" }, "0": { "text": "DOWN", "color": "red" } } }
          ],
          "max": 1,
          "min": 0
        },
        "overrides": []
      },
      "options": {
        "mergeValues": true,
        "showValue": "never",
        "rowHeight": 0.8,
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "editorMode": "code",
          "expr": "up{job=~\"svc-.*\", job=~\"$servicio\"}",
          "legendFormat": "{{job}}",
          "range": true,
          "refId": "A"
        }
      ]
    },
    {
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 21 },
      "id": 6,
      "title": "Presupuesto de Error Consumido (SLO 99.5%)",
      "type": "bargauge",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 1,
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "red", "value": 0.8 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "editorMode": "code",
          "expr": "clamp_max(((sum(rate(http_requests_total{job=~\"$servicio\", status_code=~\"5..\"}[$__range])) by (job) or (sum(rate(http_requests_total{job=~\"$servicio\"}[$__range])) by (job) * 0)) / sum(rate(http_requests_total{job=~\"$servicio\"}[$__range])) by (job)) / 0.005, 1)",
          "legendFormat": "{{job}}",
          "range": true,
          "refId": "A"
        }
      ]
    },
    {
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 21 },
      "id": 7,
      "title": "Peticiones Fallidas 5xx por Servicio (ventana 5m)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "editorMode": "code",
          "expr": "sum(rate(http_requests_total{job=~\"$servicio\", status_code=~\"5..\"}[5m])) by (job, route)",
          "legendFormat": "{{job}} {{route}}",
          "range": true,
          "refId": "A"
        }
      ]
    }
  ],
