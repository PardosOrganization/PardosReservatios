  "panels": [
    {
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "id": 1,
      "title": "Peticiones por Segundo (RPS) por Servicio",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "editorMode": "code",
          "expr": "sum(rate(http_requests_total[5m])) by (job)",
          "legendFormat": "{{job}}",
          "range": true,
          "refId": "A"
        }
      ]
    },
    {
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "id": 2,
      "title": "Errores 4xx / 5xx por Servicio",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "editorMode": "code",
          "expr": "sum(rate(http_requests_total{status_code=~\"5..\"}[5m])) by (job)",
          "legendFormat": "{{job}} 5xx",
          "range": true,
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "editorMode": "code",
          "expr": "sum(rate(http_requests_total{status_code=~\"4..\"}[5m])) by (job)",
          "legendFormat": "{{job}} 4xx",
          "range": true,
          "refId": "B"
        }
      ]
    },
    {
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "id": 3,
      "title": "Latencia p95 por Servicio",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "editorMode": "code",
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[5m])) by (le, job))",
          "legendFormat": "{{job}}",
          "range": true,
          "refId": "A"
        }
      ]
    },
    {
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "id": 4,
      "title": "Peticiones por Endpoint (Top 10)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "editorMode": "code",
          "expr": "topk(10, sum(rate(http_requests_total[5m])) by (job, route))",
          "legendFormat": "{{job}} {{route}}",
          "range": true,
          "refId": "A"
        }
      ]
    },
    {
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 16 },
      "id": 5,
      "title": "Uso de CPU del Proceso por Servicio",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": { "defaults": { "unit": "percentunit", "max": 1 }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "editorMode": "code",
          "expr": "sum(rate(process_cpu_seconds_total[5m])) by (job)",
          "legendFormat": "{{job}}",
          "range": true,
          "refId": "A"
        }
      ]
    },
    {
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 16 },
      "id": 6,
      "title": "Memoria Residente (RSS) por Servicio",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "editorMode": "code",
          "expr": "process_resident_memory_bytes",
          "legendFormat": "{{job}}",
          "range": true,
          "refId": "A"
        }
      ]
    },
    {
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 16 },
      "id": 7,
      "title": "Event Loop Lag (Node.js) por Servicio",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "editorMode": "code",
          "expr": "nodejs_eventloop_lag_seconds",
          "legendFormat": "{{job}}",
          "range": true,
          "refId": "A"
        }
      ]
    },
    {
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 24 },
      "id": 8,
      "title": "Logs de Errores (Loki)",
      "type": "logs",
      "datasource": { "type": "loki", "uid": "Loki" },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "Loki" },
          "expr": "{job=~\"svc-.*\"} |~ \"(?i)(error|critical)\"",
          "refId": "A"
        }
      ]
    }
  ],
