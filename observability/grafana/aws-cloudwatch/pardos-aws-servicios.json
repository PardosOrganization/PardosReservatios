      "type": "timeseries",
      "datasource": { "type": "cloudwatch", "uid": "${DS_CLOUDWATCH}" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "cloudwatch", "uid": "${DS_CLOUDWATCH}" },
          "namespace": "Pardos/ECS",
          "metricName": "http_requests_total",
          "statistic": "Sum",
          "dimensions": {},
          "matchExact": false,
          "region": "default",
          "label": "",
          "period": "",
          "sqlExpression": "SELECT SUM(http_requests_total) FROM \"Pardos/ECS\" GROUP BY \"service\"",
          "metricQueryType": 1,
          "metricEditorMode": 1,
          "queryMode": "Metrics"
        }
      ]
    },
