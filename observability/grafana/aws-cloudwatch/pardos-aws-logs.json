      "targets": [
        {
          "datasource": { "type": "loki", "uid": "${DS_LOKI}" },
          "expr": "{service=~\"$servicio\"}",
          "refId": "A"
        }
      ]
    }
  ],
  "schemaVersion": 38,
  "style": "dark",
  "tags": ["pardos", "logs", "loki"],
  "time": { "from": "now-6h", "to": "now" },
